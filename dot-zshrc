# zinit setup
ZINIT_HOME="$XDG_DATA_HOME/zinit/zinit.git"
if [ ! -d $ZINIT_HOME ]; then
    mkdir -p "$(dirname $ZINIT_HOME)"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "${ZINIT_HOME}/zinit.zsh"

# history & options
[ ! -d "$XDG_STATE_HOME/zsh" ] && mkdir $XDG_STATE_HOME/zsh
HISTFILE="$XDG_STATE_HOME"/zsh/history
HISTSIZE=5000
SAVEHIST=$HISTSIZE
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_find_no_dups

# zstyle completion settings
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:*' query-string ''

# prompt & external tools
zinit ice compile'(pure|async).zsh' pick'async.zsh' src'pure.zsh'
zinit light sindresorhus/pure

[ -x "$(command -v zoxide)" ] && eval "$(zoxide init zsh)"
[ -x "$(command -v mise)" ] && eval "$(mise activate zsh)"
[ -x "$(command -v fzf)" ] && eval "$(fzf --zsh)"
[ -x "$(command -v atuin)" ] && eval "$(atuin init zsh --disable-up-arrow)"

# completions, autosuggestions & syntax highlighting
zinit light zsh-users/zsh-completions
autoload -Uz compinit && compinit
export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense'
[ -x "$(command -v carapace)" ] && source <(carapace _carapace)

zinit light Aloxaf/fzf-tab
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-syntax-highlighting

# Disable terminal flow control so C-s can be used by tmux
stty -ixon

# Aliases
alias ls="ls --color=auto"
alias ll="ls -lah --color=auto"
alias gwt="new-git-worktree"

# Keybindings
bindkey -v # vi mode
bindkey '^y' autosuggest-accept
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward

function sessionize-project() {
  exec </dev/tty
  exec <&1
  ~/.local/bin/tmux-sessionizer
  zle reset-prompt > /dev/null 2>&1 || true
}
zle -N sessionize-project
bindkey '^e' sessionize-project

# Node and npm
export NVM_DIR="$XDG_CONFIG_HOME/nvm"
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
export NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npm/config"
export NPM_CONFIG_CACHE="$XDG_CACHE_HOME/npm"
export PATH="$PATH:$XDG_DATA_HOME/npm/bin"

# Local settings
[ -f $HOME/.zshrc_local ] && source $HOME/.zshrc_local

