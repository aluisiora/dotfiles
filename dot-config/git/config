[include]
    path = ./config.private
[user]
	  name = Aluisio Amaral
[core]
    editor = nvim
    compression = 9
    whitespace = error
    preloadindex = true
[init]
    defaultBranch = main
[branch]
    sort = -committerdate
[status]
    branch = true
    showStash = true
    showUntrackedFiles = all
[diff]
    context = 3
    renames = copies
    interHunkContext = 10
[push]
    autoSetupRemote = true
    default = current
    followTags = true
[pull]
    default = current
    rebase = true
[rebase]
    autoStash = true
    missingCommitsCheck = warn
[tag]
    sort = -taggerdate
[advice]
    addEmptyPathspec = false
    pushNonFastForward = false
    statusHints = false
[pager]
   branch = fzf --ansi
   tag = fzf --ansi
[log]
    graphColors = blue,yellow,cyan,magenta,green,red
[color]
	ui = auto

